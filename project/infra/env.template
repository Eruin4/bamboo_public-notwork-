# ============================================
# Bamboo Community - Environment Variables
# ============================================
# 이 파일을 .env로 복사하고 값을 채워주세요.
# cp env.template .env

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=bamboo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bamboo
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ============================================
# Redis
# ============================================
# Redis URL은 docker-compose에서 자동 설정됨

# ============================================
# Security
# ============================================
# 256비트 이상의 랜덤 문자열 생성:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# JWT 설정
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# Admin Account
# ============================================
# 서버 시작 시 이 이메일로 ADMIN 계정 생성/승격
ADMIN_PERSONAL_EMAIL=admin@example.com

# ============================================
# Upload Settings
# ============================================
# Linux 서버의 절대 경로
UPLOAD_PATH=/data/uploads
THUMB_PATH=/data/thumbs

# 이미지 제한
MAX_IMAGE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=2560
THUMB_MAX_SIZE=512

# ============================================
# Email Configuration
# ============================================
# 개발 모드: console (OTP를 로그에 출력)
# 운영 모드: smtp
EMAIL_MODE=console

# SMTP 설정 (EMAIL_MODE=smtp 일 때 필요)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=SMTP_PASSWORD_HERE

# ============================================
# Application
# ============================================
ENVIRONMENT=development
DEBUG=true

# ============================================
# Nginx Ports
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# Frontend
# ============================================
NEXT_PUBLIC_API_URL=/api

